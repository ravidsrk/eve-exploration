# Copy to .secrets/eve.env (and each archetype's .env.local is created from it by scripts/setup.sh).
# NEVER commit real keys. All files matching .env* and .secrets/ are gitignored.

# OpenRouter (model inference). https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Some scripts also read OPEN_ROUTER_KEY; set it to the same value.
OPEN_ROUTER_KEY=sk-or-v1-...

# SuperServe (sandbox microVMs). https://console.superserve.ai  (key starts ss_live_)
SUPERSERVE_API_KEY=ss_live_...

# Monid (tool router). https://app.monid.ai/access/api-keys  (key starts monid_live_)
MONID_API_KEY=monid_live_...

# Default model for the lab (a reliable, cheap tool-caller).
OPENROUTER_MODEL=openai/gpt-oss-120b

# Monid budget controls (USD). Use higher caps during Phase 0b research.
MONID_BUDGET_USD=500
MONID_MAX_CALL_USD=5

# Vercel (optional — deploy ported agents). https://vercel.com/account/tokens
VERCEL_API_KEY=
