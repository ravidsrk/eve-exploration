{
  "name": "eve-exploration",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "description": "Public catalog of real-world Vercel eve agents — reference fixtures, 50 job templates, Monid production agents, and integration proofs.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/eve-exploration.git"
  },
  "homepage": "https://github.com/ravidsrk/eve-exploration",
  "bugs": {
    "url": "https://github.com/ravidsrk/eve-exploration/issues"
  },
  "workspaces": [
    "packages/*",
    "lab",
    "agents/catalog/*",
    "agents/reference/*",
    "agents/production/*",
    "agents/integrations/*"
  ],
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "generate:catalog": "node scripts/generate-catalog.mjs --clean",
    "generate:archetypes": "npm run generate:catalog",
    "verify:catalog": "node scripts/verify-catalog.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node robustness/budget-cap.mjs",
    "test:robustness": "bash scripts/test-robustness.sh",
    "test:hitl": "bash scripts/hitl_test.sh",
    "test:durable": "bash scripts/durable_test.sh",
    "setup:monid": "bash scripts/setup-monid.sh",
    "research:monid": "node scripts/research-monid.mjs",
    "smoke:production": "node scripts/smoke-production-monid.mjs",
    "validate:reference": "bash scripts/validate-reference.sh",
    "validate:official": "npm run validate:reference",
    "run:production": "bash scripts/run-production-agent.sh",
    "run:production:all": "bash scripts/run-all-production.sh",
    "catalog:list": "node scripts/list-catalog.mjs",
    "catalog:list:md": "node scripts/list-catalog.mjs --format=md",
    "agents:list": "node scripts/list-catalog.mjs",
    "agents:list:reference": "ls -1 agents/reference",
    "agents:list:catalog": "ls -1 agents/catalog",
    "agents:list:production": "ls -1 agents/production | grep -E '^p[0-9]{2}-'",
    "agents:list:integrations": "ls -1 agents/integrations",
    "run:catalog": "bash scripts/run-catalog-agent.sh"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "1.1.1",
    "just-bash": "^3.0.1",
    "microsandbox": "^0.5.7"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.1.1"
  }
}
