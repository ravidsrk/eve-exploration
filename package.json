{
  "name": "eve-agents",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "50 job templates plus framework reference, depth examples, and integration proofs for Vercel eve.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/eve-agents.git"
  },
  "homepage": "https://github.com/ravidsrk/eve-agents",
  "bugs": {
    "url": "https://github.com/ravidsrk/eve-agents/issues"
  },
  "workspaces": [
    "packages/*",
    "agents/catalog/*",
    "agents/reference/*",
    "agents/production/*",
    "agents/integrations/*"
  ],
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "generate:catalog": "node scripts/generate-catalog.mjs --clean",
    "verify:catalog": "node scripts/verify-catalog.mjs",
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "verify:evals": "node scripts/verify-evals.mjs",
    "scaffold:evals": "node scripts/scaffold-catalog-evals.mjs",
    "scaffold:eval-config": "node scripts/scaffold-eval-config.mjs",
    "deploy:flagship": "bash scripts/deploy-flagship.sh",
    "deploy:support": "bash scripts/deploy-support.sh",
    "deploy:catalog": "bash scripts/deploy-catalog.sh",
    "smoke:deployed": "bash scripts/smoke-deployed.sh",
    "eval:deployed:flagship": "bash scripts/eval-deployed-flagship.sh",
    "eval:catalog:rotate": "node scripts/eval-catalog-rotate.mjs",
    "smoke:production:build": "bash scripts/smoke-production-all.sh",
    "test:profile": "npm run test -w @eve-agents/profile",
    "test:monid-tools": "npm run test -w @eve-agents/monid-tools",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test:all",
    "test:all": "node scripts/test-all.mjs",
    "test:structure": "npm run verify:catalog && npm run verify:runtime && npm run verify:evals && npm run test:profile",
    "eval:flagship": "bash scripts/eval-flagship.sh",
    "eval:hitl-catalog": "bash scripts/eval-catalog-hitl.sh",
    "eval:s-tier": "bash scripts/eval-s-tier.sh",
    "eval:a-tier": "bash scripts/eval-a-tier.sh",
    "test:hitl": "bash scripts/hitl_test.sh",
    "test:durable": "bash scripts/durable_test.sh",
    "smoke:production": "node scripts/smoke-production-monid.mjs",
    "validate:reference": "bash scripts/validate-reference.sh",
    "cleanup:superserve": "node scripts/cleanup-superserve.mjs",
    "run:production": "bash scripts/run-production-agent.sh",
    "run:production:all": "bash scripts/run-all-production.sh",
    "catalog:list": "node scripts/list-catalog.mjs",
    "catalog:list:md": "node scripts/list-catalog.mjs --format=md",
    "run:catalog": "bash scripts/run-catalog-agent.sh"
  },
  "devDependencies": {
    "just-bash": "^3.0.1",
    "microsandbox": "^0.5.7"
  }
}