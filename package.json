{
  "name": "eve-exploration",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A tested catalog of Vercel eve agents wired to OpenRouter, SuperServe, and Monid.",
  "workspaces": [
    "packages/*",
    "eve-lab",
    "archetypes/*"
  ],
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node robustness/budget-cap.mjs",
    "test:robustness": "bash scripts/test-robustness.sh",
    "test:hitl": "bash scripts/hitl_test.sh",
    "test:durable": "bash scripts/durable_test.sh"
  },
  "devDependencies": {
    "just-bash": "^3.0.1"
  }
}
