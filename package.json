{
  "name": "eve-exploration",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Open-source catalog of Vercel eve agents wired to OpenRouter, SuperServe, and Monid.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/eve-exploration.git"
  },
  "homepage": "https://github.com/ravidsrk/eve-exploration",
  "bugs": {
    "url": "https://github.com/ravidsrk/eve-exploration/issues"
  },
  "workspaces": [
    "packages/*",
    "eve-lab",
    "agents/official/*",
    "agents/production/*",
    "legacy/archetypes/*"
  ],
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node robustness/budget-cap.mjs",
    "test:robustness": "bash scripts/test-robustness.sh",
    "test:hitl": "bash scripts/hitl_test.sh",
    "test:durable": "bash scripts/durable_test.sh",
    "setup:monid": "bash scripts/setup-monid.sh",
    "research:monid": "node scripts/research-monid.mjs",
    "smoke:production": "node scripts/smoke-production-monid.mjs",
    "agents:list": "ls -1 agents/official",
    "agents:list:production": "ls -1 agents/production"
  },
  "devDependencies": {
    "just-bash": "^3.0.1"
  }
}
